PORT=5000

# Cambia USE_ATLAS a false para usar tu base de datos local, o a true para usar la de la nube
USE_ATLAS=false

# URI para la base de datos (Pon aquí tus credenciales)
MONGO_URI_ATLAS=mongodb+srv://<USUARIO>:<CONTRASEÑA>@<TU_CLUSTER>.mongodb.net/easytourney?retryWrites=true&w=majority
MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/easytourney

# Clave secreta para los tokens de sesión
JWT_SECRET=escribe_aqui_una_clave_secreta_aleatoria

# CONFIGURACIÓN DE MAILTRAP (o tu servicio de SMTP)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=tu_usuario_de_mailtrap
EMAIL_PASS=tu_contraseña_de_mailtrap
